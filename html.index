<!DOCTYPE html>
<html lang="en">

  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Pontus Edvard Samani</title>
    <link rel="stylesheet" href="styles.css">
  </head>

  <body>
    <h1>Encultura.org</h1>
    <ul class="poed-link-list" role="list">
    <li class="poed-link-list__item">
      <a class="poed-text-link" href="mailto:edvard.samani@encultura.org" rel="noopener">
        <span class="poed-text-link__text">Mail</span>
      </a>
      <div class="poed-link-list__text">
        Kontakta Pontus Edvard Samani.
      </div>
    </li>
    <li class="poed-link-list__item">
      <a class="poed-text-link" href="blog.encultura.org/welcome" rel="noopener">
        <span class="poed-text-link__text">Blog</span>
      </a>
      <div class="poed-link-list__text">
        Prenumerera på bloggen.
      </div>
    </li>
    <li class="poed-link-list__item">
      <a class="poed-text-link" href="notes.encultura.org" rel="noopener">
        <span class="bux-text-link__text">Notes</span>
      </a>
      <div class="poed-link-list__text">
        Läs antekningarna. 
      </div>
    </li>
    </ul>
    <script src="scripts.js"></script>
  </body>

</html>
